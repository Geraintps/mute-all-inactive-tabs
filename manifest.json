{
  "browser_specific_settings": {
    "gecko": {
      "id": "mute-inactive-tabs@voidedrl.dev"
    }
  },

  "manifest_version": 2,
  "name": "Mute Inactive Tabs",
  "version": "0.4",

  "permissions": ["storage", "tabs"],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_action": {
    "default_icon": "icons/icon-64.png",
    "default_title": "Mute Inactive Tabs",
    "default_popup": "popup.html"
  }
}
